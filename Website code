from responses import *

def process_input(text):

    if "help" in text:
        return help_menu()

    elif "order" in text and "status" in text:
        return order_status()

    elif "shipment" in text or "track" in text:
        return shipment_status()

    elif "inventory" in text or "stock" in text:
        return inventory_status()

    elif "warehouse" in text:
        return warehouse_info()

    elif "supplier" in text:
        return supplier_info()

    elif "delivery" in text:
        return delivery_schedule()

    elif "customer" in text:
        return customer_info()

    elif "product" in text:
        return product_info()

    elif "transport" in text or "vehicle" in text:
        return transport_info()

    else:
        return "Sorry, I didn't understand. Type 'help'."



